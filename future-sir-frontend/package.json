{
  "name": "future-sir-frontend",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "nodemon --env-file .env --watch .env --watch ./express.server.mjs ./express.server.mjs",
    "preview": "cross-env NODE_ENV=production nodemon --env-file .env --watch .env --watch ./express.server.mjs ./express.server.mjs",
